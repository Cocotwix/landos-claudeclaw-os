{
  "name": "claudeclaw",
  "version": "1.1.0",
  "description": "Your personal Claude Code assistant, delivered to your phone via Telegram",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx src/index.ts",
    "dev:web": "vite",
    "build": "vite build && tsc",
    "build:web": "vite build",
    "build:server": "tsc",
    "start": "node scripts/start.mjs",
    "landos:status": "node scripts/runtime/landos-runtime.mjs status",
    "landos:start": "node scripts/runtime/landos-runtime.mjs start",
    "landos:stop": "node scripts/runtime/landos-runtime.mjs stop",
    "landos:restart": "node scripts/runtime/landos-runtime.mjs restart",
    "landos:logs": "node scripts/runtime/landos-runtime.mjs logs",
    "landos:health": "node scripts/runtime/landos-runtime.mjs health",
    "landos:runtime:test": "node scripts/runtime/landos-runtime.test.mjs",
    "landos:memory:status": "node scripts/memory/landos-memory.mjs status",
    "landos:memory:audit": "node scripts/memory/landos-memory.mjs audit",
    "landos:memory:checkpoint": "node scripts/memory/landos-memory.mjs checkpoint",
    "landos:memory:retrieve": "node scripts/memory/landos-memory.mjs retrieve",
    "landos:sprint": "tsx scripts/sprint/landos-sprint-cli.ts",
    "landos:data:backup": "node scripts/data/landos-business-backup.mjs backup",
    "landos:data:restore": "node scripts/data/landos-business-backup.mjs restore",
    "landos:data:drill": "node scripts/data/landos-business-backup.mjs drill",
    "landos:data:db-drill": "node scripts/data/landos-data.mjs drill",
    "landos:qa:init": "tsx scripts/data/init-landos-qa.ts",
    "landos:operator-qa": "tsx scripts/sprint/landos-operator-qa-cli.ts",
    "landos:phase1:simulate": "tsx scripts/simulation/landos-phase1-five-lead.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "migrate": "tsx scripts/migrate.ts",
    "setup": "tsx scripts/setup.ts",
    "status": "tsx scripts/status.ts",
    "agent:create": "bash scripts/agent-create.sh",
    "agent:start": "node dist/index.js --agent",
    "uninstall": "bash scripts/uninstall.sh",
    "build:warroom-client": "esbuild warroom/client.js --bundle --outfile=warroom/client.bundle.js --format=iife --global-name=PipecatWarRoom"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.21.1",
    "@anthropic-ai/claude-agent-sdk": "^0.3.191",
    "@google/genai": "^1.44.0",
    "@hono/node-server": "^1.19.9",
    "@monaco-editor/react": "^4.7.0",
    "@slack/web-api": "^7.14.1",
    "@types/pdfkit": "^0.17.6",
    "@types/three": "^0.184.0",
    "@zed-industries/codex-acp": "^0.14.0",
    "apify-client": "^2.23.4",
    "better-sqlite3": "^11.8.1",
    "cron-parser": "^5.5.0",
    "grammy": "^1.34.0",
    "hono": "^4.12.3",
    "js-yaml": "^4.1.1",
    "monaco-editor": "^0.55.1",
    "openai": "^6.45.0",
    "pdfkit": "^0.19.1",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "qrcode-terminal": "^0.12.0",
    "three": "^0.184.0",
    "whatsapp-web.js": "^1.34.6"
  },
  "devDependencies": {
    "@pipecat-ai/client-js": "^1.7.0",
    "@pipecat-ai/websocket-transport": "^1.6.2",
    "@preact/preset-vite": "^2.10.5",
    "@preact/signals": "^2.9.0",
    "@tailwindcss/vite": "^4.2.4",
    "@types/better-sqlite3": "^7.6.12",
    "@types/d3-geo": "^3.1.0",
    "@types/dompurify": "^3.0.5",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.0",
    "@types/qrcode-terminal": "^0.12.2",
    "@types/topojson-client": "^3.1.5",
    "@vitest/coverage-v8": "^2.0.0",
    "d3-geo": "^3.1.1",
    "dompurify": "^3.4.1",
    "esbuild": "^0.28.0",
    "lucide-preact": "^1.14.0",
    "marked": "^18.0.2",
    "preact": "^10.29.1",
    "tailwindcss": "^4.2.4",
    "topojson-client": "^3.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^5.4.21",
    "vitest": "^2.0.0",
    "wouter-preact": "^3.9.0"
  },
  "engines": {
    "node": ">=20"
  },
  "vitest": {
    "environment": "node",
    "include": [
      "src/**/*.test.ts"
    ]
  }
}
